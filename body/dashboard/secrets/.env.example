# Copy to secrets/.env (gitignored) and fill in real values.

# Random secret for signing session cookies, e.g.: openssl rand -hex 32
DASHBOARD_SECRET_KEY=changeme

# bcrypt hash of the shared admin password, e.g.:
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
# IMPORTANT: `docker compose` interpolates `$VAR`/`${VAR}` inside env_file
# values, and a bcrypt hash is made almost entirely of `$` delimiters —
# double every literal `$` as `$$` here, or the hash gets silently
# truncated/corrupted (empty-string-substituted) and login fails with
# "ValueError: Invalid salt". Example: $2b$12$abc... -> $$2b$$12$$abc...
DASHBOARD_ADMIN_PASSWORD_HASH=changeme

# Must match tools/audit-tap's polling interval (minutes) so staleness
# detection lines up. Default 5.
DASHBOARD_POLL_INTERVAL_MINUTES=5
